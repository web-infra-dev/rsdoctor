{
  "extends": "@rsdoctor/tsconfig/base",
  "compilerOptions": {
    "experimentalDecorators": true,
    "outDir": "./dist",
    "paths": {
      "@rsdoctor/core/graph": ["../core/src/graph/index.ts"],
      "@rsdoctor/core/logger": ["../core/src/logger.ts"],
      "@rsdoctor/core/sdk": ["../core/src/sdk.ts"],
      "@/*": ["./src/*"]
    },
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["**/node_modules"],
  "references": [
    {
      "path": "../shared/tsconfig.json"
    },
    {
      "path": "../core/tsconfig.json"
    }
  ]
}
