{
  "name": "@rsdoctor/core",
  "version": "1.5.11",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rsdoctor",
    "directory": "packages/core"
  },
  "license": "MIT",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "compiled",
    "static"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./build-utils": {
      "import": {
        "types": "./dist/build-utils/index.d.ts",
        "default": "./dist/build-utils/index.js"
      },
      "require": {
        "types": "./dist/build-utils/index.d.cts",
        "default": "./dist/build-utils/index.cjs"
      }
    },
    "./collection": {
      "import": {
        "types": "./dist/collection.d.ts",
        "default": "./dist/collection.js"
      },
      "require": {
        "types": "./dist/collection.d.cts",
        "default": "./dist/collection.cjs"
      }
    },
    "./common": {
      "import": {
        "types": "./dist/common/index.d.ts",
        "default": "./dist/common/index.js"
      },
      "require": {
        "types": "./dist/common/index.d.cts",
        "default": "./dist/common/index.cjs"
      }
    },
    "./error": {
      "import": {
        "types": "./dist/error/index.d.ts",
        "default": "./dist/error/index.js"
      },
      "require": {
        "types": "./dist/error/index.d.cts",
        "default": "./dist/error/index.cjs"
      }
    },
    "./logger": {
      "import": {
        "types": "./dist/logger.d.ts",
        "default": "./dist/logger.js"
      },
      "require": {
        "types": "./dist/logger.d.cts",
        "default": "./dist/logger.cjs"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/inner-plugins/index.d.ts",
        "default": "./dist/inner-plugins/index.js"
      },
      "require": {
        "types": "./dist/inner-plugins/index.d.cts",
        "default": "./dist/inner-plugins/index.cjs"
      }
    },
    "./rules": {
      "import": {
        "types": "./dist/rules/index.d.ts",
        "default": "./dist/rules/index.js"
      },
      "require": {
        "types": "./dist/rules/index.d.cts",
        "default": "./dist/rules/index.cjs"
      }
    },
    "./rule-utils": {
      "import": {
        "types": "./dist/rule-utils/index.d.ts",
        "default": "./dist/rule-utils/index.js"
      },
      "require": {
        "types": "./dist/rule-utils/index.d.cts",
        "default": "./dist/rule-utils/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/types/index.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "build-utils": [
        "./dist/build-utils/index.d.ts"
      ],
      "collection": [
        "./dist/collection.d.ts"
      ],
      "common": [
        "./dist/common/index.d.ts"
      ],
      "error": [
        "./dist/error/index.d.ts"
      ],
      "logger": [
        "./dist/logger.d.ts"
      ],
      "plugins": [
        "./dist/inner-plugins/index.d.ts"
      ],
      "rules": [
        "./dist/rules/index.d.ts"
      ],
      "rule-utils": [
        "./dist/rule-utils/index.d.ts"
      ],
      "types": [
        "./dist/types/index.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "npm run start",
    "build": "npm run prebundle && rslib build",
    "start": "rslib build -w",
    "test": "rstest run",
    "prebundle": "prebundle"
  },
  "dependencies": {
    "@babel/code-frame": "7.26.2",
    "@rsbuild/plugin-check-syntax": "catalog:",
    "@rsdoctor/graph": "workspace:*",
    "@rsdoctor/types": "workspace:*",
    "@rspack/resolver": "catalog:",
    "@types/estree": "catalog:",
    "acorn": "^8.10.0",
    "acorn-import-attributes": "^1.9.5",
    "acorn-walk": "8.3.5",
    "browserslist-load-config": "^1.0.3",
    "connect": "3.7.0",
    "deep-eql": "4.1.4",
    "envinfo": "7.21.0",
    "es-toolkit": "catalog:",
    "filesize": "catalog:",
    "fs-extra": "catalog:",
    "get-port": "5.1.1",
    "json-stream-stringify": "3.0.1",
    "lines-and-columns": "2.0.4",
    "open": "^10.2.0",
    "path-browserify": "catalog:",
    "picocolors": "catalog:",
    "rslog": "^2.1.2",
    "semver": "^7.7.4",
    "source-map": "catalog:",
    "strip-ansi": "^6.0.1"
  },
  "devDependencies": {
    "@rspack/core": "catalog:",
    "@scripts/test-helper": "workspace:*",
    "@types/babel__code-frame": "7.27.0",
    "@types/connect": "catalog:",
    "@types/deep-eql": "4.0.2",
    "@types/envinfo": "7.8.4",
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "@types/node-fetch": "^2.6.13",
    "@types/path-browserify": "catalog:",
    "@types/semver": "^7.7.1",
    "@types/tapable": "catalog:",
    "babel-loader": "10.1.1",
    "prebundle": "catalog:",
    "string-loader": "0.0.1",
    "ts-loader": "^9.5.7",
    "tslib": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
