{
  "extends": "@rsdoctor/tsconfig/base",
  "compilerOptions": {
    "experimentalDecorators": true,
    "declarationMap": false,
    "outDir": "dist",
    "paths": {
      "@rsdoctor/core": ["./src/index.ts"],
      "@rsdoctor/core/*": ["./src/*"],
      "@rsdoctor/core/plugins": ["./src/inner-plugins/index.ts"],
      "@/*": ["./src/*"],
      "src": ["./src"],
      "src/*": ["./src/*"]
    },
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["**/node_modules"],
  "references": [
    {
      "path": "../shared/tsconfig.json"
    }
  ]
}
