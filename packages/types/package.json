{
  "name": "@rsdoctor/types",
  "version": "1.5.9",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rsdoctor",
    "directory": "packages/types"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch"
  },
  "dependencies": {
    "@types/connect": "catalog:",
    "@types/estree": "catalog:",
    "@types/tapable": "catalog:",
    "source-map": "catalog:"
  },
  "devDependencies": {
    "@rspack/core": "2.0.0-rc.3",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@rspack/core": "*",
    "webpack": "5.x"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
